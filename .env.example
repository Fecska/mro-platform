# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mro_platform
POSTGRES_USER=mro_user
POSTGRES_PASSWORD=change_me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=mro_user
RABBITMQ_PASSWORD=change_me

# Auth (Keycloak or custom OIDC)
AUTH_ISSUER=http://localhost:8080/realms/mro
AUTH_CLIENT_ID=mro-api
AUTH_CLIENT_SECRET=change_me

# Storage (S3-compatible)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=mro-documents
STORAGE_ACCESS_KEY=change_me
STORAGE_SECRET_KEY=change_me

# API
API_PORT=5000
API_BASE_URL=http://localhost:5000

# Web
WEB_PORT=3000
WEB_BASE_URL=http://localhost:3000

# Signing
SIGNATURE_SECRET=change_me

# Environment
ENVIRONMENT=development
