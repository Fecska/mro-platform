# ── Railway environment variables ─────────────────────────────────────────────
# Set these in the Railway service → Variables tab

# Database (Railway auto-fills this when you attach a PostgreSQL plugin)
ConnectionStrings__Postgres=Host=...;Port=5432;Database=railway;Username=postgres;Password=...

# JWT — generate a strong random secret (min. 32 chars)
# Example: openssl rand -hex 32
Jwt__SecretKey=REPLACE_WITH_STRONG_SECRET_MIN_32_CHARS
Jwt__Issuer=https://mro-api.up.railway.app
Jwt__Audience=mro-api

# CORS — set to your Vercel URL after first deployment
# Example: https://mro-web.vercel.app
Cors__AllowedOrigins__0=https://REPLACE_WITH_VERCEL_URL

# AWS S3 (only needed for document upload features)
# AWS__Region=eu-west-1
# AWS__S3__BucketName=mro-documents

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
